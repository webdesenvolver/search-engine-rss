# .htaccess - Configuração Apache

# Habilitar mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirecionar requisições para arquivos/diretórios existentes
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Prevenir acesso direto a diretórios sensíveis
    RewriteRule ^(config\.php|classes|cron|logs|data)(.*)$ - [L,F]
</IfModule>

# Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>

# Cache headers
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Cache de 1 ano para arquivos estáticos
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # Cache de 1 mês para CSS/JS
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Sem cache para HTML
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Permitir acesso a sitemap.xml
<Files sitemap.xml>
    Allow from all
</Files>

# Bloquear acesso a .env, .git, etc
<FilesMatch "^\.|\.env|\.git|\.gitignore|composer\.(json|lock)">
    Order allow,deny
    Deny from all
</FilesMatch>
